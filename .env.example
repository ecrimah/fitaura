# Application
NEXT_PUBLIC_APP_URL=https://shopfitaura.com

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Email (Resend) — optional
RESEND_API_KEY=
ADMIN_EMAIL=admin@shopfitaura.com
EMAIL_FROM=FITAURA <noreply@shopfitaura.com>

# Stripe payment gateway (required for checkout)
#   - Publishable key (pk_test_… or pk_live_…) is shipped to the browser.
#   - Secret key (sk_test_… or sk_live_…) is server-only — never expose it.
#   - Webhook secret (whsec_…) is given to you by `stripe listen` (dev)
#     or by the Dashboard → Developers → Webhooks (prod).
#     Endpoint URL to register: https://YOUR_DOMAIN/api/payment/stripe/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SMS (Moolre) — optional (transactional SMS only, not payments)
MOOLRE_SMS_API_KEY=
MOOLRE_API_KEY=

# Analytics, Search Console & reCAPTCHA — optional
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Cron (payment reminders)
CRON_SECRET=
